Stock By Warehouse Name
SELECT
	SUM(quantityInStock) AS stock, warehouseName
FROM
	mintclassics.products
LEFT JOIN
	mintclassics.warehouses ON products.warehouseCode = warehouses.warehouseCode
GROUP BY
	warehouseName
Excess Stock By Product Name
SELECT 
    DISTINCT productName, SUM(quantityOrdered) AS total, quantityInStock, 
    (quantityInStock - SUM(quantityOrdered)) AS excess, 
    (SUM(quantityOrdered) / quantityInStock) AS turnover
